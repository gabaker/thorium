#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CURRENT_SECTION="startup"
trap 'echo "FATAL: Failed in \"$CURRENT_SECTION\" at line $LINENO (command: $BASH_COMMAND)" >&2' ERR

log() { echo -e "\n====== $1 ======\n"; }

wait_for_rollout() {
    local resource=$1 namespace=$2 timeout=${3:-300}
    minikube kubectl -- rollout status --watch --timeout="${timeout}s" "$resource" -n "$namespace"
}

wait_for_resource() {
    local resource_type=$1 resource_name=$2 namespace=$3 timeout=${4:-300}
    local elapsed=0
    echo "Waiting for $resource_type/$resource_name in $namespace (timeout: ${timeout}s)..."
    until minikube kubectl -- get "$resource_type" "$resource_name" -n "$namespace" &>/dev/null; do
        sleep 5
        elapsed=$((elapsed + 5))
        if [ "$elapsed" -ge "$timeout" ]; then
            echo "ERROR: Timed out waiting for $resource_type/$resource_name in $namespace" >&2
            return 1
        fi
    done
}

wait_for_port_forward() {
    local port=$1 max_attempts=${2:-20}
    for attempt in $(seq 1 "$max_attempts"); do
        if curl -sf -o /dev/null "http://localhost:$port" 2>/dev/null; then return 0; fi
        sleep 1
    done
    echo "ERROR: Port-forward on port $port not ready after ${max_attempts}s" >&2
    return 1
}

########################################
# Section 0: Wait for healthy cluster
########################################
CURRENT_SECTION="Wait for healthy cluster"
wait_for_healthy_cluster() {
    minikube kubectl -- wait --for=condition=Ready node/minikube --timeout=120s

    # Core kube-system components
    minikube kubectl -- wait --for=condition=Ready pod -l k8s-app=calico-node -n kube-system --timeout=120s
    minikube kubectl -- wait --for=condition=Ready pod -l k8s-app=calico-kube-controllers -n kube-system --timeout=120s
    minikube kubectl -- wait --for=condition=Ready pod -l k8s-app=kube-dns -n kube-system --timeout=120s
    minikube kubectl -- rollout status deployment.apps/coredns -n kube-system --timeout=120s

    # CSI hostpath driver (required for PVC provisioning)
    minikube kubectl -- wait --for=condition=Ready pod -l app.kubernetes.io/name=csi-hostpath-attacher -n kube-system --timeout=120s
    minikube kubectl -- wait --for=condition=Ready pod -l app.kubernetes.io/name=csi-hostpath-resizer -n kube-system --timeout=120s
    minikube kubectl -- wait --for=condition=Ready pod -l app.kubernetes.io/name=csi-hostpathplugin -n kube-system --timeout=120s

    # Ingress controller
    minikube kubectl -- wait --for=condition=Ready pod -l app.kubernetes.io/component=controller -n ingress-nginx --timeout=120s
}

log "Waiting for cluster to be healthy"
max_retries=30
retry_delay=10
for attempt in $(seq 1 $max_retries); do
    output=$(wait_for_healthy_cluster 2>&1) && break
    if echo "$output" | grep -q 'cluster .* does not exist'; then
        echo "Cluster not ready yet (attempt $attempt/$max_retries), retrying in ${retry_delay}s..."
        sleep "$retry_delay"
        if [ "$attempt" -eq "$max_retries" ]; then
            echo "Cluster did not become ready after $max_retries attempts"
            exit 1
        fi
    else
        echo "$output" >&2
        exit 1
    fi
done

