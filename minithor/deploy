########################################
# Section 13: Create test user
########################################
CURRENT_SECTION="Create test user"
log "Creating test admin user"
API_POD=$(minikube kubectl -- get pod -n thorium -l app=api -o jsonpath='{.items[0].metadata.name}')
CREATE_RESP=$(minikube kubectl -- -n thorium exec -i "pod/$API_POD" -- \
    curl -s -w '\n%{http_code}' -X POST http://localhost/api/users/ \
    -H 'Content-Type: application/json' \
    -H 'secret-key: INSECURE_DEV_PASSWORD' \
    -d '{"username":"test","password":"INSECURE_DEV_PASSWORD","email":"test@localhost","role":"Admin","local":true,"skip_verification":true}')
HTTP_CODE=$(echo "$CREATE_RESP" | tail -1)
BODY=$(echo "$CREATE_RESP" | sed '$d')
if [ "$HTTP_CODE" = "200" ]; then
    echo "Test admin user created successfully"
    echo "  Username: test"
    echo "  Password: INSECURE_DEV_PASSWORD"
elif echo "$BODY" | grep -q "already exists"; then
    echo "Test admin user already exists, skipping"
else
    echo "WARNING: Failed to create test user (HTTP $HTTP_CODE): $BODY"
fi

########################################
# Section 14: Install thorctl & import toolbox
########################################
CURRENT_SECTION="Install thorctl & import toolbox"

log "Installing thorctl"

# Kill any stale thorium port-forwards from previous runs
pkill -f 'port-forward svc/thorium-api' 2>/dev/null || true

# Port-forward the API so we can reach it from the host
PF_PORT=$((RANDOM % 55000 + 10000))
minikube kubectl -- -n thorium port-forward svc/thorium-api "$PF_PORT":80 &
PF_PID=$!
trap 'kill $PF_PID 2>/dev/null; kill -9 $PF_PID 2>/dev/null; pkill -9 -f "port-forward svc/thorium-api" 2>/dev/null' EXIT
wait_for_port_forward "$PF_PORT" 20

THORCTL_URL="http://localhost:$PF_PORT"

OS=$(uname -s | awk '{print tolower($0)}')
HARDWARE=$(uname -m | tr '_' '-')

THORCTL_BIN="$SCRIPT_DIR/thorctl"
echo "Downloading thorctl for $OS/$HARDWARE..."
curl -sf "$THORCTL_URL/api/binaries/$OS/$HARDWARE/thorctl" -o "$THORCTL_BIN"
chmod +x "$THORCTL_BIN"

log "Logging into Thorium via thorctl"
"$THORCTL_BIN" login "$THORCTL_URL" --user test --password INSECURE_DEV_PASSWORD

log "Creating 'static' group and 'allow-all' network policy"
BASIC_AUTH=$(echo -n 'test:INSECURE_DEV_PASSWORD' | base64)
minikube kubectl -- -n thorium exec -i "pod/$API_POD" -- \
    curl -sf -X POST http://localhost/api/groups/ \
    -H "Authorization: Basic $BASIC_AUTH" \
    -H 'Content-Type: application/json' \
    -d '{"name":"static"}' || true
minikube kubectl -- -n thorium exec -i "pod/$API_POD" -- \
    curl -sf -X POST http://localhost/api/network-policies \
    -H "Authorization: Basic $BASIC_AUTH" \
    -H 'Content-Type: application/json' \
    -d '{"name":"allow-all","groups":["static"],"ingress":[],"egress":null,"forced_policy":false,"default_policy":false}' || true

log "Importing toolbox"
curl -o "$SCRIPT_DIR/toolbox.json"  https://raw.githubusercontent.com/cisagov/thorium/refs/heads/main/tools/toolbox.json
"$THORCTL_BIN" toolbox import "$SCRIPT_DIR/toolbox.json" -y

log "Deployment complete!"
echo ""
echo "Access Thorium:"
echo "  1. Run 'minikube tunnel' in a separate terminal"
echo "  2. Open http://localhost in your browser"
echo "  3. Login with username 'test' and password 'INSECURE_DEV_PASSWORD'"