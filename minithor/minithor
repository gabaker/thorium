                | grep -v '^pod ' | tr -d '\r')

            kctl create secret generic registry-auth -n thorium \
                --from-literal=htpasswd="$htpasswd_entry" \
                --from-literal=username="$registry_user" \
                --from-literal=password="$REGISTRY_PASS" \
                --dry-run=client -o yaml | kctl apply -f -

            reg_auth_config='
    auth:
      htpasswd:
        realm: "Thorium Registry"
        path: /auth/htpasswd'
            reg_auth_env='
            - name: REGISTRY_AUTH
              value: "htpasswd"
            - name: REGISTRY_AUTH_HTPASSWD_REALM
              value: "Thorium Registry"
            - name: REGISTRY_AUTH_HTPASSWD_PATH
              value: "/auth/htpasswd"'
            reg_auth_vol='
        - name: auth
          secret:
            secretName: registry-auth
            items:
              - key: htpasswd
                path: htpasswd'
            reg_auth_mount='
            - name: auth
              mountPath: /auth
              readOnly: true'
        fi

        kctl apply -f - <<REGEOF
