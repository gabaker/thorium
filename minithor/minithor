    else
        kctl apply -f - <<'EOF'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: operator
  namespace: thorium
  labels:
    app: operator
spec:
  replicas: 1
  selector:
    matchLabels:
      app: operator
  template:
    metadata:
      labels:
        app: operator
    spec:
      serviceAccountName: thorium
      automountServiceAccountToken: true
      containers:
        - name: operator
          image: ghcr.io/cisagov/thorium/infrastructure/thorium:latest
          imagePullPolicy: Always
          resources:
            requests:
              memory: 0
              cpu: 0
            limits:
              memory: 1Gi
