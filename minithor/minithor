        wait_for_rollout statefulset/registry thorium "$deploy_timeout"

        log "Verifying registry"
        local catalog_response
        catalog_response=$(kctl -n thorium exec "pod/registry-0" -- \
            wget -qO- "http://localhost:5000/v2/_catalog" 2>/dev/null) || true
        if echo "$catalog_response" | grep -q "repositories"; then
            echo "Registry is healthy: $catalog_response"
