        kctl apply -f "$default_config" -n thorium
        rm -f "$default_config"
    fi

    ########################################
    # Wait for Thorium components
    ########################################
    CURRENT_SECTION="Wait for Thorium components"

    log "Waiting for Thorium components to start"

    echo "Waiting for API deployment..."
    wait_for_resource deployment api thorium "$deploy_timeout"
    wait_for_rollout deployment.apps/api thorium "$deploy_timeout"

    echo "Waiting for scaler deployment..."
    wait_for_resource deployment scaler thorium "$deploy_timeout"
    wait_for_rollout deployment.apps/scaler thorium "$deploy_timeout"

    echo "Waiting for event-handler deployment..."
    wait_for_resource deployment event-handler thorium "$deploy_timeout"
    wait_for_rollout deployment.apps/event-handler thorium "$deploy_timeout"

    echo "Waiting for search-streamer deployment..."
    wait_for_resource deployment search-streamer thorium "$deploy_timeout"
    wait_for_rollout deployment.apps/search-streamer thorium "$deploy_timeout"

    log "All Thorium components are running"

    ########################################
    # Create test user
    ########################################
    CURRENT_SECTION="Create test user"
    log "Creating test admin user"
    API_POD=$(kctl get pod -n thorium -l app=api -o jsonpath='{.items[0].metadata.name}')
    CREATE_RESP=$(kctl -n thorium exec -i "pod/$API_POD" -- \
        curl -s -w '\n%{http_code}' -X POST http://localhost/api/users/ \
        -H 'Content-Type: application/json' \
        -H "secret-key: $THORIUM_SECRET" \
        -d "{\"username\":\"$deploy_user\",\"password\":\"$deploy_pass\",\"email\":\"${deploy_user}@localhost\",\"role\":\"Admin\",\"local\":true,\"skip_verification\":true}")
    HTTP_CODE=$(echo "$CREATE_RESP" | tail -1)
    BODY=$(echo "$CREATE_RESP" | sed '$d')
    if [ "$HTTP_CODE" = "200" ]; then
        echo "Admin user created successfully"
        echo "  Username: $deploy_user"
        echo "  Password: $deploy_pass"
    elif echo "$BODY" | grep -q "already exists"; then
        echo "Test admin user already exists, skipping"
    else
        echo "WARNING: Failed to create test user (HTTP $HTTP_CODE): $BODY"
    fi

    ########################################
    # Install thorctl & import toolbox
    ########################################
    CURRENT_SECTION="Install thorctl & import toolbox"

    log "Installing thorctl"

    pkill -f 'port-forward svc/thorium-api' 2>/dev/null || true

    PF_PORT=8080
    kctl -n thorium port-forward svc/thorium-api "$PF_PORT":80 &
    PF_PID=$!
    trap 'kill $PF_PID 2>/dev/null; kill -9 $PF_PID 2>/dev/null; pkill -9 -f "port-forward svc/thorium-api" 2>/dev/null || true' EXIT
    wait_for_port_forward "$PF_PORT" 20

    THORCTL_URL="http://localhost:$PF_PORT"

    local thorctl_os thorctl_hw
    thorctl_os=$(uname -s | awk '{print tolower($0)}')
    thorctl_hw=$(uname -m | tr '_' '-')

    THORCTL_BIN="$bin_dir/thorctl"
    echo "Downloading thorctl to $THORCTL_BIN for $thorctl_os/$thorctl_hw..."
    sudo curl -sf "$THORCTL_URL/api/binaries/$thorctl_os/$thorctl_hw/thorctl" -o "$THORCTL_BIN"
    sudo chmod +x "$THORCTL_BIN"

    log "Logging into Thorium via thorctl"
    "$THORCTL_BIN" login "$THORCTL_URL" --user "$deploy_user" --password "$deploy_pass"

    log "Creating 'static' group and 'allow-all' network policy"
    BASIC_AUTH=$(echo -n "$deploy_user:$deploy_pass" | base64)
    kctl -n thorium exec -i "pod/$API_POD" -- \
        curl -sf -X POST http://localhost/api/groups/ \
        -H "Authorization: Basic $BASIC_AUTH" \
        -H 'Content-Type: application/json' \
        -d '{"name":"static"}' || true
    kctl -n thorium exec -i "pod/$API_POD" -- \
        curl -sf -X POST http://localhost/api/network-policies \
        -H "Authorization: Basic $BASIC_AUTH" \
        -H 'Content-Type: application/json' \
        -d '{"name":"allow-all","groups":["static"],"ingress":[],"egress":null,"forced_policy":false,"default_policy":false}' || true

    log "Importing toolbox"
    curl -o "$toolbox_path" https://raw.githubusercontent.com/cisagov/thorium/refs/heads/main/tools/toolbox.json
    echo "Toolbox downloaded to $toolbox_path"
    "$THORCTL_BIN" toolbox import "$toolbox_path" -y

    ########################################
    # Optional: Container Registry
    ########################################
    if [ "$deploy_registry" = true ]; then
        CURRENT_SECTION="Container Registry"
        log "Deploying Container Registry"

        local reg_auth_env=""
        local reg_auth_vol=""
        local reg_auth_mount=""
        local reg_auth_config=""
        local REGISTRY_PASS=""

        if [ -n "$registry_user" ]; then
            REGISTRY_PASS=$(generate_password)
            echo "Configuring registry basic auth for user '$registry_user'..."

            local htpasswd_entry
