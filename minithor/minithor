EOF

    wait_for_rollout deployment.apps/operator thorium "$deploy_timeout"

    log "Waiting for operator to register ThoriumCluster CRD"
    wait_for_resource crd thoriumclusters.sandia.gov "" "$deploy_timeout"
    kctl wait --for condition=established \
        crd/thoriumclusters.sandia.gov --timeout="${deploy_timeout}s"

    ########################################
    # ThoriumCluster CRD
    ########################################
    CURRENT_SECTION="ThoriumCluster CRD"
    log "Creating ThoriumCluster resource"
    if [ -f "$cluster_config" ]; then
        kctl apply -f "$cluster_config" -n thorium
    else
        echo "No cluster config found at $cluster_config, using built-in default" >&2
        local default_config
        default_config=$(mktemp)
        cat > "$default_config" <<DEFEOF
apiVersion: sandia.gov/v1
kind: ThoriumCluster
metadata:
  name: dev
  namespace: thorium
spec:
  registry: "ghcr.io/cisagov/thorium/infrastructure/thorium"
  version: "latest"
  image_pull_policy: Always
  components:
    api:
      replicas: 1
      resources:
        cpu: 0
        memory: 0
    scaler:
      service_account: true
      resources:
        cpu: 0
        memory: 0
    search_streamer:
      resources:
        cpu: 0
        memory: 0
      cmd:
        - "/app/thorium-search-streamer"
      args:
        - "--config"
        - "/conf/thorium.yml"
        - "--keys"
        - "/keys/keys.yml"
    event_handler:
      resources:
        cpu: 0
        memory: 0
  config:
    thorium:
      secret_key: "$THORIUM_SECRET"
      tracing:
        external:
          Grpc:
