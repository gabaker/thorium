run_step minikube kubectl -- delete statefulsets,deployments,services,pods --all -n scylla --force --grace-period=0 --ignore-not-found --timeout=60s
run_step minikube kubectl -- delete ns scylla --ignore-not-found --timeout=300s
helm_uninstall scylla-operator scylla-operator
run_step minikube kubectl -- delete ns scylla-operator --ignore-not-found --timeout=300s

########################################
# cert-manager
########################################
CURRENT_SECTION="Removing cert-manager"
