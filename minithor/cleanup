run_step minikube kubectl -- delete deployment webhook-server -n scylla-operator --ignore-not-found --timeout=60s
# Remove finalizers from ScyllaCluster CRs so the namespace can terminate.
if minikube kubectl -- get crd scyllaclusters.scylla.scylladb.com &>/dev/null; then
