run_step minikube kubectl -- delete ns cert-manager --ignore-not-found --timeout=300s

########################################
# Elasticsearch
########################################
CURRENT_SECTION="Removing Elasticsearch"
log "Removing Elasticsearch"
helm_uninstall elastic-operator elastic-system
# Remove finalizers from Elasticsearch/Kibana CRs so the namespace can terminate.
if minikube kubectl -- get crd elasticsearches.elasticsearch.k8s.elastic.co &>/dev/null; then
    for es in $(minikube kubectl -- get elasticsearches.elasticsearch.k8s.elastic.co -n elastic-system -o name 2>/dev/null); do
        run_step minikube kubectl -- patch "$es" -n elastic-system --type merge -p '{"metadata":{"finalizers":[]}}'
    done
    run_step minikube kubectl -- delete elasticsearches.elasticsearch.k8s.elastic.co --all -n elastic-system --ignore-not-found --timeout=60s
fi
if minikube kubectl -- get crd kibanas.kibana.k8s.elastic.co &>/dev/null; then
    for kb in $(minikube kubectl -- get kibanas.kibana.k8s.elastic.co -n elastic-system -o name 2>/dev/null); do
        run_step minikube kubectl -- patch "$kb" -n elastic-system --type merge -p '{"metadata":{"finalizers":[]}}'
    done
    run_step minikube kubectl -- delete kibanas.kibana.k8s.elastic.co --all -n elastic-system --ignore-not-found --timeout=60s
fi
run_step minikube kubectl -- delete statefulsets,deployments,services,pods --all -n elastic-system --force --grace-period=0 --ignore-not-found --timeout=60s
run_step minikube kubectl -- delete ns elastic-system --ignore-not-found --timeout=300s

########################################
# Redis
########################################
CURRENT_SECTION="Removing Redis"
log "Removing Redis"
run_step minikube kubectl -- delete ns redis --ignore-not-found --timeout=300s

########################################
# Leftover CRDs
########################################
CURRENT_SECTION="Cleaning up CRDs"
log "Cleaning up leftover CRDs"
CRDS=$(minikube kubectl -- get crds -o name 2>/dev/null | grep -E 'cert-manager|elastic|scylla|kubegres|sandia' || true)
if [ -n "$CRDS" ]; then
    run_step minikube kubectl -- delete $CRDS --timeout=300s
fi

########################################
# Wait for namespace termination
########################################
CURRENT_SECTION="Waiting for namespace termination"
log "Waiting for namespaces to terminate"
run_step wait_for_ns_termination 300

########################################
# Summary
########################################
if [ "$FAILURES" -gt 0 ]; then
    log "Cleanup finished with $FAILURES failure(s)"
    minikube kubectl -- get ns
    exit 1
else
    log "Cleanup complete"
    minikube kubectl -- get ns
fi