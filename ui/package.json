{
  "name": "thorium-frontend",
  "description": "Web UI for Thorium 1.x",
  "type": "module",
  "private": true,
  "version": "1.6.1",
  "scripts": {
    "lint": "node_modules/eslint/bin/eslint.js src",
    "fix": "node_modules/eslint/bin/eslint.js src --fix",
    "build": "tsc -p tsconfig.prod.json && vite build --mode production",
    "build-check": "tsc -p tsconfig.json && vite build --mode production",
    "build-preview": "vite build --mode preview",
    "dev": "vite",
    "format": "prettier src --write",
    "validate-style": "prettier src --check",
    "preview": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cisagov/thorium.git`"
  },
  "bugs": {
    "url": "https://github.com/cisagov/thorium/issues"
  },
  "dependencies": {
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "axios": "^1.14.0",
    "bootstrap": "^5.3.8",
    "classnames": "^2.5.1",
    "core-js": "^3.49.0",
    "country-list": "^2.4.1",
    "cytoscape": "^3.33.1",
    "cytoscape-cise": "^2.0.1",
    "cytoscape-cose-bilkent": "^4.1.0",
    "cytoscape-elk": "^2.3.0",
    "cytoscape-fcose": "^2.2.0",
    "cytoscape-svg": "^0.4.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "font-awesome": "^4.7.0",
    "html-react-parser": "^5.2.17",
    "is-ip": "^5.0.1",
    "js-cookie": "^3.0.5",
    "json-bigint": "^1.0.0",
    "raw-loader": "^4.0.2",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-complex-tree": "^2.6.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.4",
    "react-dropzone": "^14.4.1",
    "react-error-boundary": "^6.1.1",
    "react-icons": "^5.6.0",
    "react-intersection-observer": "^10.0.3",
    "react-json-tree": "^0.20.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.6.2",
    "react-router-dom": "^7.13.2",
    "react-select": "^5.10.2",
    "react-syntax-highlighter": "^16.1.1",
    "react-toastify": "^11.0.5",
    "react-xml-viewer": "^3.0.3",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.2",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/country-list": "^2.1.4",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "es-check": "^9.6.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "source-map-loader": "^5.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vite-plugin-eslint": "^1.8.1"
  },
  "overrides": {
    "react-syntax-highlighter": {
      "prismjs": "1.30.0"
    },
    "react-xml-viewer": {
      "fast-xml-parser": "5.5.9"
    }
  }
}
