{
  "name": "thorium-frontend",
  "description": "Web UI for Thorium 1.x",
  "type": "module",
  "private": true,
  "version": "1.7.0",
  "scripts": {
    "lint": "node_modules/eslint/bin/eslint.js src",
    "fix": "node_modules/eslint/bin/eslint.js src --fix",
    "build": "tsc -p tsconfig.prod.json && vite build --mode production",
    "build-check": "tsc -p tsconfig.json && vite build --mode production",
    "build-preview": "vite build --mode preview",
    "dev": "vite",
    "format": "prettier src --write",
    "validate-style": "prettier src --check",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cisagov/thorium.git`"
  },
  "bugs": {
    "url": "https://github.com/cisagov/thorium/issues"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "3d-force-graph": "^1.80.0",
    "axios": "^1.16.0",
    "bootstrap": "^5.3.8",
    "classnames": "^2.5.1",
    "core-js": "^3.49.0",
    "country-list": "^2.4.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.2",
    "font-awesome": "^4.7.0",
    "html-react-parser": "^5.2.17",
    "is-ip": "^5.0.1",
    "js-cookie": "^3.0.5",
    "json-bigint": "^1.0.0",
    "raw-loader": "^4.0.2",
    "react": "^19.2.6",
    "react-bootstrap": "^2.10.10",
    "react-complex-tree": "^2.6.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.6",
    "react-dropzone": "^14.4.1",
    "react-error-boundary": "^6.1.1",
    "react-icons": "^5.6.0",
    "react-intersection-observer": "^10.0.3",
    "react-json-tree": "^0.20.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.6.2",
    "react-router-dom": "^7.15.0",
    "react-select": "^5.10.2",
    "react-syntax-highlighter": "^16.1.1",
    "react-toastify": "^11.1.0",
    "react-xml-viewer": "^3.0.4",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.3",
    "styled-components": "^6.4.1",
    "three": "^0.184.0",
    "three-spritetext": "^1.10.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@playwright/test": "^1.60.0",
    "@types/country-list": "^2.1.4",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "es-check": "^9.6.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.8",
    "source-map-loader": "^5.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.3.3",
    "vite-plugin-eslint": "^1.8.1",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "react-syntax-highlighter": {
      "prismjs": "1.30.0"
    },
    "react-xml-viewer": {
      "fast-xml-parser": "5.5.9"
    }
  }
}
