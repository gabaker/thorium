{ 
  "compilerOptions": {
    "jsx": "react-jsx",
    "extends": "./tsconfig.json",
    "compilerOptions": {
      "checkJs": true
    },
    "esModuleInterop": true,
    "target": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@assets": ["./src/assets/*"],
      "@styles": ["./src/styles/index.ts"],
      "@components/*": ["./src/components/*"],
      "@models/*": ["./src/models/*"],
      "@thorpi/*": ["./src/thorpi/*"],
      "@utilities/*": ["./src/utilities/*"],
      "@entities/*": ["./src/components/entities/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"],
}
